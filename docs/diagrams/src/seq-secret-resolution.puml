@startuml seq-secret-resolution

title Amadla — Secret Resolution Flow

skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderColor #444

participant "Pipeline\n(weaver, etc.)" as pipeline
participant "doorman\ndaemon" as doorman
participant "Encrypted\nCache" as cache
participant "doorman-vault\nplugin" as plugin
database "Vault /\nOpenBao" as vault

== Cache Hit ==
pipeline -> doorman : Resolve secret:\n"tls-certificate"
doorman -> cache : Lookup "tls-certificate"
cache --> doorman : Found (not expired)
doorman -> cache : Decrypt value
cache --> doorman : Plaintext secret
doorman --> pipeline : Secret value

== Cache Miss ==
pipeline -> doorman : Resolve secret:\n"db-password"
doorman -> cache : Lookup "db-password"
cache --> doorman : Not found
doorman -> plugin : IPC: fetch\n"secret/data/db-password"
plugin -> vault : GET /v1/secret/data/db-password
vault --> plugin : {"data": {"password": "..."}}
plugin --> doorman : Secret value
doorman -> cache : Encrypt + store\nwith TTL
doorman --> pipeline : Secret value

== Cache Expired ==
pipeline -> doorman : Resolve secret:\n"api-key"
doorman -> cache : Lookup "api-key"
cache --> doorman : Found but expired
doorman -> plugin : IPC: refresh\n"secret/data/api-key"
plugin -> vault : GET /v1/secret/data/api-key
vault --> plugin : {"data": {"key": "..."}}
plugin --> doorman : Secret value
doorman -> cache : Re-encrypt + store\nwith new TTL
doorman --> pipeline : Secret value

@enduml
